# ============================================================
# NATAPrep Backend — Environment Variables
# Copy this to .env and fill in values for local dev
# Set these as Railway env vars for production
# ============================================================

# App
ENVIRONMENT=production
DEBUG=false

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_32_char_secret

# Database — Railway provides this automatically as $DATABASE_URL
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Redis — Railway provides this automatically as $REDIS_URL
REDIS_URL=redis://default:password@host:6379

# Celery (uses same Redis, different DBs)
CELERY_BROKER_URL=redis://default:password@host:6379/1
CELERY_RESULT_BACKEND=redis://default:password@host:6379/2

# AI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# CORS — comma-separated list of allowed frontend origins
# Add your Vercel URL here after deploying
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
